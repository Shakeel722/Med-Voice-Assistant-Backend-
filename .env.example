# Med Voice Assistant Backend - Environment Configuration
# Copy this file to .env and fill in your values when connecting to external databases

# ============================================================================
# Database Configuration
# ============================================================================
# Leave commented out to use SQLite (default for development)
# Uncomment and fill in when your friend builds the external database

# For PostgreSQL:
# DB_ENGINE=postgresql
# DB_NAME=medvoice_db
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_HOST=your_database_host.com
# DB_PORT=5432

# For MySQL:
# DB_ENGINE=mysql
# DB_NAME=medvoice_db
# DB_USER=root
# DB_PASSWORD=your_secure_password
# DB_HOST=your_database_host.com
# DB_PORT=3306

# ============================================================================
# Django Settings
# ============================================================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# CORS Settings
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
